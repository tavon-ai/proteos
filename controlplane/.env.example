# Control-plane configuration (Phase 1). Copy to .env and fill in.

# HTTP listen address.
PROTEOS_ADDR=:8080

# Externally-reachable origin (used for OAuth callback + cookie scoping).
PROTEOS_BASE_URL=http://localhost:8080

# Postgres DSN (matches compose.dev.yml).
DATABASE_URL=postgres://proteos:proteos@localhost:5432/proteos?sslmode=disable

# Zitadel OIDC login (TAV-149): the IdP host and the app's client id (public
# client + PKCE, no secret). Redirect URI: <PROTEOS_BASE_URL>/api/auth/callback.
ZITADEL_DOMAIN=auth.tavon.io
ZITADEL_CLIENT_ID=

# GitHub App user-authorization credentials (see docs/github-app-setup.md).
# Since TAV-149 these back the post-login "Connect GitHub" flow, not login.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# The App's URL slug (github.com/apps/<slug>). Builds the "choose which repos
# ProteOS can access" link in the Repos panel; leave empty to omit that link
# (the repo flow still works). See docs/github-app-sharing-repos.md.
GITHUB_APP_SLUG=

# HMAC key for signing the short-lived OAuth state cookie (use a long random string).
PROTEOS_STATE_KEY=

# Dev secrets file (gitignored). OpenBao replaces this in Phase 5.
PROTEOS_SECRETS_FILE=.data/secrets.json

# Optional allowlist of GitHub logins that may be linked via Connect GitHub.
# Empty = allow all. (Signup gating moved to Zitadel with TAV-149.)
ALLOWED_GITHUB_LOGINS=

# Set to false only for exotic local setups without HTTPS-on-localhost support.
PROTEOS_COOKIE_SECURE=true
