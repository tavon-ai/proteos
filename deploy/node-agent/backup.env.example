# ProteOS node-agent LUKS volume backup config (TAV-31). Optional — every var
# below has a built-in default; copy this file only if you want to override
# something (e.g. retention, an off-host rsync target). backup-volumes.sh and
# restore-volumes.sh both source deploy/node-agent/.env first (for
# PROTEOS_AGENT_VOLUMES_DIR / PROTEOS_CRYPTSETUP_BIN) and then this file if
# present.
#
#   cp backup.env.example backup.env && $EDITOR backup.env      # local run
#   sudo cp backup.env.example /etc/proteos/backup.env           # systemd timer
#
# See docs/disaster-recovery.md.

PROTEOS_VOLUME_BACKUP_DIR=/var/backups/proteos/volumes
# Snapshots to keep (not days — volume sizes vary a lot machine to machine).
PROTEOS_VOLUME_BACKUP_RETENTION=7
# Push every snapshot off this host after it completes — a backup on the same
# disk as the primary is not a backup. rsync destination spec, e.g.:
# PROTEOS_VOLUME_BACKUP_REMOTE=proteos-backup@offsite.example:/backups/proteos/volumes/
PROTEOS_VOLUME_BACKUP_REMOTE=
