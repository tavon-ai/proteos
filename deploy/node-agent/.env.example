# ProteOS node-agent (Firecracker driver) — KVM host config.
# Copy to `.env` in this directory and fill in. Sourced by run-node-agent.sh
# and by the systemd unit (as /etc/proteos/node-agent.env).

# Shared bearer token. MUST be identical to the app stack's PROTEOS_AGENT_TOKEN.
# Generate once: openssl rand -hex 32
PROTEOS_AGENT_TOKEN=CHANGE_ME

# Listen address. Use 0.0.0.0 so the (separate) app VM can reach the agent.
# Lock this down with a host firewall: allow :9090 ONLY from the app VM's IP.
PROTEOS_AGENT_ADDR=0.0.0.0:9090

PROTEOS_AGENT_DRIVER=firecracker

# Host paths. The data dir holds per-VM state.json + the IP allocator; the jail
# base is the jailer --chroot-base-dir; images dir holds the pinned kernel+rootfs.
PROTEOS_AGENT_DATA_DIR=/var/lib/proteos/agent
PROTEOS_CHROOT_BASE_DIR=/srv/jailer
PROTEOS_AGENT_IMAGES_DIR=/var/lib/proteos/images

# Pinned firecracker + jailer binaries. The spike installs them under
# ~/fc-spike/bin (see spike/firecracker/01-host-setup.sh). Either point these at
# that location or copy them to /usr/local/bin first.
PROTEOS_FIRECRACKER_BIN=/usr/local/bin/firecracker
PROTEOS_JAILER_BIN=/usr/local/bin/jailer

# Per-host guest subnet. The agent allocates the lowest free address; .1 is the
# gateway. Keep this off any subnet the host/app VM already use.
PROTEOS_AGENT_SUBNET=172.30.0.0/24

# --- Phase 4: persistent disk + hibernate/resume --------------------------------

# Where per-machine LUKS volume container files live (<id>.luks). MUST be OUTSIDE
# the jail tree (PROTEOS_CHROOT_BASE_DIR) so per-boot jail teardown never deletes
# them. Holds the persistent disk, the writable rootfs copy, and snapshot files —
# all encrypted at rest.
PROTEOS_AGENT_VOLUMES_DIR=/var/lib/proteos/volumes

# cryptsetup binary used to format/open/close the machine volume.
PROTEOS_CRYPTSETUP_BIN=/usr/sbin/cryptsetup

# Optional TLS: once volume keys flow over this channel (Phase 4 decision #3),
# serve HTTPS by setting both. The control plane pins this cert via
# PROTEOS_NODE_CA_FILE. Leave unset for a plaintext loopback/dev channel.
# PROTEOS_AGENT_TLS_CERT=/etc/proteos/agent.crt
# PROTEOS_AGENT_TLS_KEY=/etc/proteos/agent.key

# Image filenames inside PROTEOS_AGENT_IMAGES_DIR. Used here ONLY for the
# preflight existence check — they MUST match the control plane's
# PROTEOS_KERNEL_REF / PROTEOS_ROOTFS_REF (the control plane stamps the refs on
# each machine and the driver resolves them against the images dir).
PROTEOS_KERNEL_REF=vmlinux
PROTEOS_ROOTFS_REF=ubuntu-24.04.ext4
