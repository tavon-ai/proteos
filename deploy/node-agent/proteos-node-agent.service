# systemd unit for the ProteOS node-agent (Firecracker driver).
#
# Install (on the KVM host):
#   sudo mkdir -p /opt/proteos /etc/proteos
#   sudo cp -r <repo> /opt/proteos/src           # or git clone into /opt/proteos/src
#   sudo cp /opt/proteos/src/deploy/node-agent/.env.example /etc/proteos/node-agent.env
#   sudo $EDITOR /etc/proteos/node-agent.env     # set the token + paths
#   sudo /opt/proteos/src/deploy/node-agent/run-node-agent.sh build   # build the binary once
#   sudo cp /opt/proteos/src/deploy/node-agent/proteos-node-agent.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now proteos-node-agent
#   journalctl -u proteos-node-agent -f
#
# Adjust ExecStart if your checkout is not at /opt/proteos/src.

[Unit]
Description=ProteOS node-agent (Firecracker driver)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
EnvironmentFile=/etc/proteos/node-agent.env
ExecStart=/opt/proteos/src/deploy/node-agent/run-node-agent.sh run
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
