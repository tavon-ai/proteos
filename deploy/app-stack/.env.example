# ProteOS app stack (db + control plane + web). Copy to `.env` and fill in.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=proteos
POSTGRES_PASSWORD=proteos
POSTGRES_DB=proteos

# --- Browser-facing origin --------------------------------------------------
# The single origin the browser hits = the `web` nginx, published on WEB_PORT.
# PROTEOS_BASE_URL must match it exactly (scheme+host+port) AND match the
# GitHub App callback URL: <PROTEOS_BASE_URL>/api/auth/github/callback
WEB_PORT=8080
PROTEOS_BASE_URL=http://APP_VM_IP:8080
# Plain HTTP -> cookies cannot be Secure. Put TLS in front (Caddy/nginx) for
# anything real, then set this back to true.
PROTEOS_COOKIE_SECURE=false

# --- Secrets backend (Phase 5) ----------------------------------------------
# "file" (default) uses the dev JSON store on the cpdata volume. Switch to
# "openbao" AFTER running deploy/app-stack/openbao-init.sh, which fills in
# PROTEOS_OPENBAO_ROLE_ID below and writes the secret_id to ./openbao-secret-id.
# See RUNBOOK Part D.
PROTEOS_SECRETS_BACKEND=file
PROTEOS_OPENBAO_ADDR=http://openbao:8200
PROTEOS_OPENBAO_MOUNT=secret
# Set by openbao-init.sh; leave blank until then.
PROTEOS_OPENBAO_ROLE_ID=

# --- node-agent (native, on the KVM host) -----------------------------------
PROTEOS_NODE_AGENT_URL=http://KVM_HOST_IP:9090
# MUST equal the node-agent's PROTEOS_AGENT_TOKEN. openssl rand -hex 32
PROTEOS_AGENT_TOKEN=CHANGE_ME
PROTEOS_HOST_NAME=proxmox-fc-1
# Phase 4: pin the node-agent's TLS cert/CA (PEM) once the agent serves HTTPS
# (it now carries per-machine volume keys). Leave unset for a plaintext channel.
# PROTEOS_NODE_CA_FILE=/etc/proteos/node-agent-ca.pem

# --- machine image refs (must match files in the agent's images dir) --------
PROTEOS_KERNEL_REF=vmlinux
PROTEOS_ROOTFS_REF=ubuntu-24.04.ext4
PROTEOS_MACHINE_VCPUS=2
PROTEOS_MACHINE_MEM_MIB=2048
# Phase 4: persistent disk size provisioned per machine (MiB).
PROTEOS_MACHINE_DISK_MIB=10240

# Phase 8: parent domain for per-machine code-server editor subdomains
# (m-<uuid>.<domain>). Requires a wildcard DNS record *.<domain> and a wildcard
# TLS cert at your proxy (NPMplus) — see DEPLOYMENT.md. Leave UNSET to disable
# the editor (no wildcard infra needed). Example:
# PROTEOS_MACHINE_DOMAIN=machines.proteos.example
PROTEOS_MACHINE_DOMAIN=

# --- GitHub OAuth (Phase 1 auth) --------------------------------------------
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Signs the OAuth state cookie. openssl rand -hex 32
PROTEOS_STATE_KEY=
# Optional comma-separated signup allowlist; empty = anyone may sign in.
ALLOWED_GITHUB_LOGINS=

# --- GitHub git operations (Phase 7) ----------------------------------------
# The App's URL slug (github.com/apps/<slug>): builds the "choose which repos
# ProteOS can access" link in the Repos panel. Find it in the App's settings URL.
GITHUB_APP_SLUG=
# Host clones target and the credential helper mints tokens for. Leave default;
# only the e2e harness overrides it to a local git server.
PROTEOS_GIT_HOST=github.com
