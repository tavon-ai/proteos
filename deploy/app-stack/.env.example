# ProteOS app stack (db + control plane + web). Copy to `.env` and fill in.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=proteos
POSTGRES_PASSWORD=proteos
POSTGRES_DB=proteos

# --- Browser-facing origin --------------------------------------------------
# The single origin the browser hits = the `web` nginx, published on WEB_PORT.
# PROTEOS_BASE_URL must match it exactly (scheme+host+port) AND match the
# GitHub App callback URL: <PROTEOS_BASE_URL>/api/auth/github/callback
WEB_PORT=8080
PROTEOS_BASE_URL=http://APP_VM_IP:8080
# Plain HTTP -> cookies cannot be Secure. Put TLS in front (Caddy/nginx) for
# anything real, then set this back to true.
PROTEOS_COOKIE_SECURE=false

# --- node-agent (native, on the KVM host) -----------------------------------
PROTEOS_NODE_AGENT_URL=http://KVM_HOST_IP:9090
# MUST equal the node-agent's PROTEOS_AGENT_TOKEN. openssl rand -hex 32
PROTEOS_AGENT_TOKEN=CHANGE_ME
PROTEOS_HOST_NAME=proxmox-fc-1

# --- machine image refs (must match files in the agent's images dir) --------
PROTEOS_KERNEL_REF=vmlinux
PROTEOS_ROOTFS_REF=ubuntu-24.04.ext4
PROTEOS_MACHINE_VCPUS=2
PROTEOS_MACHINE_MEM_MIB=2048

# --- GitHub OAuth (Phase 1 auth) --------------------------------------------
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Signs the OAuth state cookie. openssl rand -hex 32
PROTEOS_STATE_KEY=
# Optional comma-separated signup allowlist; empty = anyone may sign in.
ALLOWED_GITHUB_LOGINS=
