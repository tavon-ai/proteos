# ProteOS app-stack backup config (TAV-31). Optional — every var below has a
# built-in default; copy this file only if you want to override something
# (e.g. retention, an off-host rsync target). backup-postgres.sh,
# backup-openbao.sh, and backup-all.sh all source deploy/app-stack/.env first
# (for POSTGRES_USER/POSTGRES_DB) and then this file if present.
#
#   cp backup.env.example backup.env && $EDITOR backup.env      # local run
#   sudo cp backup.env.example /etc/proteos/backup.env           # systemd timer
#
# See docs/disaster-recovery.md.

# --- Postgres (backup-postgres.sh / restore-postgres.sh) --------------------
PROTEOS_PG_BACKUP_DIR=/var/backups/proteos/postgres
PROTEOS_PG_BACKUP_RETENTION_DAYS=14
# Push every dump off this host after it completes — a backup on the same
# disk as the primary is not a backup. rsync destination spec, e.g.:
# PROTEOS_PG_BACKUP_REMOTE=proteos-backup@offsite.example:/backups/proteos/postgres/
PROTEOS_PG_BACKUP_REMOTE=

# --- OpenBao (backup-openbao.sh / restore-openbao.sh) -----------------------
PROTEOS_OPENBAO_BACKUP_DIR=/var/backups/proteos/openbao
PROTEOS_OPENBAO_BACKUP_RETENTION_DAYS=14
# PROTEOS_OPENBAO_BACKUP_REMOTE=proteos-backup@offsite.example:/backups/proteos/openbao/
PROTEOS_OPENBAO_BACKUP_REMOTE=
# Only needed if the compose project name changed from the default "proteos"
# (compose.yaml pins it via the top-level `name:` field).
PROTEOS_BAODATA_VOLUME=proteos_baodata
