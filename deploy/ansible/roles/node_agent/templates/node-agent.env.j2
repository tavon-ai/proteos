# {{ ansible_managed }}
# ProteOS node-agent (Firecracker driver) — rendered by Ansible.
# Sourced by run-node-agent.sh and the systemd unit. Do not edit by hand; change
# the Ansible vars instead. See deploy/node-agent/.env.example for field docs.

# Shared bearer token. MUST be identical to the app stack's PROTEOS_AGENT_TOKEN.
PROTEOS_AGENT_TOKEN={{ proteos_agent_token }}

PROTEOS_AGENT_ADDR={{ proteos_agent_addr }}
PROTEOS_AGENT_DRIVER={{ proteos_agent_driver }}

PROTEOS_AGENT_DATA_DIR={{ proteos_data_dir }}
PROTEOS_CHROOT_BASE_DIR={{ proteos_chroot_base_dir }}
PROTEOS_AGENT_IMAGES_DIR={{ proteos_images_dir }}

PROTEOS_FIRECRACKER_BIN={{ proteos_firecracker_bin }}
PROTEOS_JAILER_BIN={{ proteos_jailer_bin }}

PROTEOS_AGENT_SUBNET={{ proteos_agent_subnet }}

# Interfaces allowed through the agent's fail-closed nftables input chain
# ("egress" ⇒ default-route iface). Must include the control plane's arrival
# path — tailscale0 in production.
PROTEOS_AGENT_MGMT_IFACES={{ proteos_agent_mgmt_ifaces }}

# Phase 4: persistent disk + hibernate/resume.
PROTEOS_AGENT_VOLUMES_DIR={{ proteos_volumes_dir }}
PROTEOS_CRYPTSETUP_BIN={{ proteos_cryptsetup_bin }}

# Preflight image refs — MUST match the control plane's PROTEOS_KERNEL_REF /
# PROTEOS_ROOTFS_REF.
PROTEOS_KERNEL_REF={{ proteos_kernel_ref }}
PROTEOS_ROOTFS_REF={{ proteos_rootfs_ref }}

# TLS for the agent channel (TAV-27: mandatory — the API carries volume keys).
# Self-signed by the play unless proteos_agent_tls_cert/key point elsewhere;
# the app stack pins this cert via PROTEOS_NODE_CA_FILE.
PROTEOS_AGENT_TLS_CERT={{ proteos_agent_tls_cert_effective }}
PROTEOS_AGENT_TLS_KEY={{ proteos_agent_tls_key_effective }}
