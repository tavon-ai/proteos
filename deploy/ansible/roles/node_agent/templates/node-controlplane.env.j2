{{ ansible_managed }}
# ProteOS node controlplane resources for {{ inventory_hostname }} — generated by
# Ansible on the controller so you don't have to SSH in and grep node-agent.env.
# CONTAINS THE SHARED BEARER TOKEN — treat as a secret (this file is mode 0600).
#
# Source it (`set -a; . node-{{ inventory_hostname }}.env; set +a`) or read the
# values into your control-plane config. The matching template catalog is the
# sibling proteos-templates.json (the app stack's PROTEOS_TEMPLATES_FILE).

PROTEOS_AGENT_TOKEN={{ proteos_agent_token }}
PROTEOS_ROOTFS_REF={{ proteos_rootfs_ref }}
PROTEOS_KERNEL_REF={{ proteos_kernel_ref }}

# Where the control plane reaches this node-agent. Prefers the tailnet IP when the
# host joined a tailnet (proteos_tailscale_enabled), else the inventory address.
PROTEOS_NODE_ADDR={{ (proteos_tailscale_ip | default(ansible_host, true)) }}:{{ proteos_agent_port }}
{% if proteos_tailscale_ip is defined %}
PROTEOS_NODE_TAILSCALE_IP={{ proteos_tailscale_ip }}
{% endif %}

# Sibling file fetched alongside this one (app stack's PROTEOS_TEMPLATES_FILE).
PROTEOS_TEMPLATES_FILE={{ proteos_templates_fetch_dir }}/proteos-templates.json
