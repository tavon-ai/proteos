{# Control-plane machine-template catalog (PROTEOS_TEMPLATES_FILE). Generated by
   the node_agent role from proteos_templates + the per-template baked image
   names. kernel_ref is intentionally omitted: the control plane fills it from its
   own PROTEOS_KERNEL_REF, so the kernel image name lives on one host only. #}
{
  "templates": [
{% for t in proteos_templates %}
    {
      "id": {{ t.id | to_json }},
      "label": {{ t.label | to_json }},
      "description": {{ t.description | to_json }},
      "rootfs_ref": {{ proteos_template_images[t.id] | to_json }},
      "defaults": { "vcpus": {{ t.vcpus | int }}, "mem_mib": {{ t.mem_mib | int }}, "disk_mib": {{ t.disk_mib | int }} }
    }{{ "," if not loop.last else "" }}
{% endfor %}
  ]
}
