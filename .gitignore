# OpenBao operator secrets (Phase 5) — never commit. openbao-init.sh writes
# the AppRole secret_id here, the unseal key to bao-unseal-key, and the
# unseal/root material to openbao-init.json.
deploy/app-stack/openbao-secret-id
deploy/app-stack/openbao-init.json
deploy/app-stack/bao-unseal-key

# Operator-local Ansible inventory (copy from inventory.example.ini); holds
# real host IPs/users and must never be committed.
deploy/ansible/inventory.ini

# Backup config (TAV-31) — operator-local overrides (retention, off-host rsync
# targets) copied from backup.env.example; not secret by default but keep
# operator-specific hostnames/paths out of git same as the other env files.
deploy/app-stack/backup.env
deploy/node-agent/backup.env

# Web build output / deps
web/node_modules/
web/dist/

# CLI build output
cli/dist/

.serena/
